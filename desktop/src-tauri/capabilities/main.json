{
  "$schema": "https://schema.tauri.app/capabilities/2",
  "identifier": "main",
  "description": "Allow dialog open and event listen for main window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:event:allow-listen",
    "dialog:default",
    "dialog:allow-open"
  ]
}
