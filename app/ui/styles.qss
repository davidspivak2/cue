QWidget {{
  background-color: {BG};
  color: {TEXT};
  font-family: "Segoe UI", "Inter", sans-serif;
  font-size: 12px;
}}

QMainWindow {{
  background-color: {BG};
}}

QLabel {{
  color: {TEXT};
}}

QLabel#DropZoneHeadline {{
  font-size: 18px;
  font-weight: bold;
}}

QLabel#DropZoneSubtext {{
  color: {MUTED_TEXT};
}}

QFrame#DropZone {{
  border: 2px dashed {BORDER};
  border-radius: {RADIUS}px;
  background-color: {SURFACE};
  padding: {SPACING_LG}px;
}}

QFrame#DropZone[dragOver="true"] {{
  border-color: {ACCENT};
  background-color: {SURFACE_2};
}}

QWidget#VideoCard {{
  border: 1px solid {BORDER};
  border-radius: {RADIUS}px;
  background-color: {SURFACE};
  padding: {SPACING_MD}px;
}}

QWidget#VideoCard[dragOver="true"] {{
  border-color: {ACCENT};
}}

QFrame#VideoCardThumbnail {{
  border: 1px solid {BORDER};
  border-radius: {RADIUS}px;
  background-color: {SURFACE_2};
}}

QLabel#VideoCardFilename {{
  font-size: 14px;
  font-weight: bold;
}}

QLabel#VideoCardDuration {{
  color: {MUTED_TEXT};
}}

QLabel#VideoCardPlaceholder {{
  color: {MUTED_TEXT};
  font-size: 12px;
}}

QLabel#SavingToPrefix,
QLabel#SavingToPath {{
  color: {MUTED_TEXT};
  font-size: 12px;
}}

QToolButton#SettingsButton {{
  background-color: transparent;
  border: none;
}}

QToolButton#SettingsButton:hover {{
  background-color: {SURFACE_2};
  border-radius: 4px;
}}

QPushButton#SettingsBackButton {{
  background-color: transparent;
  border: none;
  color: {ACCENT};
  padding: 0;
}}

QPushButton#SettingsBackButton:hover {{
  color: {TEXT};
}}

QLabel#SettingsTitle {{
  font-size: 18px;
  font-weight: bold;
}}

QLabel#SettingsHelperText {{
  color: {MUTED_TEXT};
  font-size: 13px;
}}

QLabel#SettingsRunSummary {{
  color: {MUTED_TEXT};
}}

QFrame#SettingsSectionCard {{
  border: 1px solid {BORDER};
  border-radius: {RADIUS}px;
  background-color: {SURFACE};
}}

QLabel#SettingsSectionTitle {{
  font-size: 13px;
  font-weight: 600;
}}

QFrame#SettingsSectionCard QLabel,
QFrame#SettingsSectionCard QCheckBox,
QFrame#SettingsSectionCard QRadioButton {{
  font-size: 13px;
}}

QToolButton#VideoCardClear {{
  background-color: rgba(0, 0, 0, 0.5);
  border: 1px solid {BORDER};
  border-radius: 13px;
  color: {TEXT};
}}

QToolButton#VideoCardClear:hover {{
  border: 1px solid {ACCENT};
  color: {TEXT};
}}

QToolButton#VideoCardClear:pressed {{
  background-color: rgba(0, 0, 0, 0.7);
  color: {TEXT};
}}

QGroupBox {{
  border: 1px solid {BORDER};
  border-radius: {RADIUS}px;
  margin-top: {SPACING_MD}px;
  padding: {SPACING_MD}px;
}}

QGroupBox::title {{
  color: {MUTED_TEXT};
  subcontrol-origin: margin;
  left: {SPACING_SM}px;
  padding: 0 {SPACING_SM}px;
}}

QLineEdit,
QPlainTextEdit,
QTextEdit {{
  background-color: {SURFACE};
  color: {TEXT};
  border: 1px solid {BORDER};
  border-radius: {RADIUS}px;
  padding: {SPACING_SM}px;
  selection-background-color: {ACCENT};
}}

QLineEdit:focus,
QPlainTextEdit:focus,
QTextEdit:focus {{
  border: 1px solid {ACCENT};
}}

QPushButton {{
  background-color: {SURFACE_2};
  color: {TEXT};
  border: 1px solid {BORDER};
  border-radius: {RADIUS}px;
  padding: {SPACING_SM}px {SPACING_MD}px;
}}

QPushButton:hover {{
  background-color: {SURFACE};
  border: 1px solid {ACCENT};
}}

QPushButton:pressed {{
  background-color: {BG};
}}

QPushButton#PresetOption {{
  background-color: transparent;
  border: none;
  padding: 2px 0;
  text-align: left;
}}

QPushButton#PresetOption:checked {{
  color: {ACCENT};
  font-weight: 600;
}}

QPushButton#SegmentedLeft,
QPushButton#SegmentedMiddle,
QPushButton#SegmentedRight {{
  border-radius: 0;
  padding: {SPACING_SM}px {SPACING_MD}px;
}}

QPushButton#SegmentedLeft {{
  border-top-left-radius: {RADIUS}px;
  border-bottom-left-radius: {RADIUS}px;
  border-right: none;
}}

QPushButton#SegmentedMiddle {{
  border-right: none;
}}

QPushButton#SegmentedRight {{
  border-top-right-radius: {RADIUS}px;
  border-bottom-right-radius: {RADIUS}px;
}}

QPushButton#SegmentedLeft:checked,
QPushButton#SegmentedMiddle:checked,
QPushButton#SegmentedRight:checked {{
  background-color: {ACCENT};
  border-color: {ACCENT};
  color: {TEXT};
}}

QPushButton#SaveToChange {{
  background-color: transparent;
  border: none;
  color: {ACCENT};
  padding: 0;
}}

QPushButton#SaveToChange:hover {{
  color: {TEXT};
}}

QPushButton#SaveToChange:disabled {{
  color: {MUTED_TEXT};
}}

QProgressBar {{
  background-color: {SURFACE};
  border: 1px solid {BORDER};
  border-radius: {RADIUS}px;
  text-align: center;
  color: {TEXT};
  height: 18px;
}}

QProgressBar::chunk {{
  background-color: {ACCENT};
  border-radius: {RADIUS}px;
}}

QScrollBar:vertical {{
  background: {SURFACE_2};
  width: 10px;
  margin: 0px;
}}

QScrollBar::handle:vertical {{
  background: {BORDER};
  min-height: 20px;
  border-radius: 5px;
}}

QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {{
  background: none;
  height: 0px;
}}
