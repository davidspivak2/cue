# -*- mode: python ; coding: utf-8 -*-
from __future__ import annotations

import os

from PyInstaller.utils.hooks import (
    collect_all,
    collect_dynamic_libs,
    collect_submodules,
)

block_cipher = None

project_dir = os.path.abspath(".")


def safe_collect_all(package_name: str) -> tuple[list[tuple[str, str]], list[tuple[str, str]], list[str]]:
    try:
        return collect_all(package_name)
    except Exception:
        return ([], [], [])


def safe_collect_dynamic_libs(package_name: str) -> list[tuple[str, str]]:
    try:
        return collect_dynamic_libs(package_name)
    except Exception:
        return []


def safe_collect_submodules(package_name: str) -> list[str]:
    try:
        return collect_submodules(package_name)
    except Exception:
        return []


binaries: list[tuple[str, str]] = []
ffmpeg_path = os.path.join(project_dir, "bin", "ffmpeg.exe")
ffprobe_path = os.path.join(project_dir, "bin", "ffprobe.exe")
if os.path.exists(ffmpeg_path):
    binaries.append((ffmpeg_path, "bin"))
if os.path.exists(ffprobe_path):
    binaries.append((ffprobe_path, "bin"))

datas: list[tuple[str, str]] = [
    (os.path.join("app", "ui", "styles.qss"), os.path.join("app", "ui"))
]
hiddenimports: list[str] = []

for package_name in (
    "faster_whisper",
    "ctranslate2",
    "tokenizers",
    "av",
    "whisperx",
    "torch",
    "torchaudio",
):
    pkg_datas, pkg_binaries, pkg_hidden = safe_collect_all(package_name)
    datas += pkg_datas
    binaries += pkg_binaries
    hiddenimports += pkg_hidden

binaries += safe_collect_dynamic_libs("av")

hiddenimports += safe_collect_submodules("av")
hiddenimports += safe_collect_submodules("whisperx")
hiddenimports += safe_collect_submodules("torch")
hiddenimports += safe_collect_submodules("torchaudio")

runtime_hooks = [os.path.join("runtime_hooks", "runtime_env_setup.py")]

from PyInstaller.building.build_main import Analysis, EXE, PYZ, COLLECT  # noqa: E402


def script_name(entry: object) -> str:
    name = getattr(entry, "name", None)
    if name:
        return name
    if isinstance(entry, tuple) and entry:
        return str(entry[0])
    return str(entry)


a = Analysis(
    ["run_backend.py", "run_runner.py", "run_worker.py", "run_align_worker.py"],
    pathex=[project_dir],
    binaries=binaries,
    datas=datas,
    hiddenimports=hiddenimports,
    hookspath=[],
    runtime_hooks=runtime_hooks,
    excludes=[],
    win_no_prefer_redirects=False,
    win_private_assemblies=False,
    cipher=block_cipher,
    noarchive=False,
)

pyz = PYZ(a.pure, a.zipped_data, cipher=block_cipher)

backend_exe = EXE(
    pyz,
    [
        script
        for script in a.scripts
        if os.path.splitext(script_name(script))[0] == "run_backend"
    ],
    [],
    exclude_binaries=True,
    name="CueBackend",
    debug=False,
    bootloader_ignore_signals=False,
    strip=False,
    upx=True,
    console=False,
    disable_windowed_traceback=False,
)

runner_exe = EXE(
    pyz,
    [
        script
        for script in a.scripts
        if os.path.splitext(script_name(script))[0] == "run_runner"
    ],
    [],
    exclude_binaries=True,
    name="CueRunner",
    debug=False,
    bootloader_ignore_signals=False,
    strip=False,
    upx=True,
    console=False,
    disable_windowed_traceback=False,
)

worker_exe = EXE(
    pyz,
    [
        script
        for script in a.scripts
        if os.path.splitext(script_name(script))[0] == "run_worker"
    ],
    [],
    exclude_binaries=True,
    name="CueWorker",
    debug=False,
    bootloader_ignore_signals=False,
    strip=False,
    upx=True,
    console=False,
    disable_windowed_traceback=False,
)

align_exe = EXE(
    pyz,
    [
        script
        for script in a.scripts
        if os.path.splitext(script_name(script))[0] == "run_align_worker"
    ],
    [],
    exclude_binaries=True,
    name="CueAlignWorker",
    debug=False,
    bootloader_ignore_signals=False,
    strip=False,
    upx=True,
    console=False,
    disable_windowed_traceback=False,
)

coll = COLLECT(
    backend_exe,
    runner_exe,
    worker_exe,
    align_exe,
    a.binaries,
    a.zipfiles,
    a.datas,
    strip=False,
    upx=True,
    upx_exclude=[],
    name="CueEngine",
)
