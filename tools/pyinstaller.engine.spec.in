# -*- mode: python ; coding: utf-8 -*-
from __future__ import annotations

import os
from collections.abc import Callable

from PyInstaller.utils.hooks import (
    collect_all,
    collect_dynamic_libs,
    collect_submodules,
)

block_cipher = None

project_dir = os.path.abspath(".")
EXCLUDED_PACKAGE_EXTENSIONS = {
    ".a",
    ".c",
    ".cuh",
    ".cpp",
    ".exp",
    ".h",
    ".hpp",
    ".ilk",
    ".lib",
    ".pdb",
    ".pxd",
    ".pxi",
    ".pyi",
    ".pyx",
    ".tp",
}
EXCLUDED_PACKAGE_FILE_NAMES = {"meson.build", "readme", "readme.md", "readme.txt"}
EXCLUDED_PACKAGE_PATH_PARTS = {"tests", "testing"}
EXCLUDED_PACKAGE_PATH_SNIPPETS = {
    "sklearn/datasets/data/",
    "sklearn/datasets/descr/",
    "sklearn/datasets/images/",
    "sklearn/svm/src/",
}


def collect_or_empty(collector: Callable[[str], object], package_name: str, fallback: object) -> object:
    try:
        return collector(package_name)
    except Exception:
        return fallback


def packaged_entry_path(entry: object) -> str:
    name = getattr(entry, "name", None)
    if name:
        return str(name)
    if isinstance(entry, tuple) and entry:
        return str(entry[0])
    return str(entry)


def packaged_path_parts(path: str) -> list[str]:
    return [part.lower() for part in path.replace("\\", "/").split("/") if part]


def is_runtime_packaged_path(path: str) -> bool:
    normalized_path = "/".join(packaged_path_parts(path))
    file_name = os.path.basename(path).lower()
    if os.path.splitext(path)[1].lower() in EXCLUDED_PACKAGE_EXTENSIONS:
        return False
    if file_name in EXCLUDED_PACKAGE_FILE_NAMES:
        return False
    if any(part in EXCLUDED_PACKAGE_PATH_PARTS for part in packaged_path_parts(path)):
        return False
    return not any(snippet in normalized_path for snippet in EXCLUDED_PACKAGE_PATH_SNIPPETS)


def is_runtime_packaged_entry(entry: tuple[str, ...]) -> bool:
    return is_runtime_packaged_path(packaged_entry_path(entry))


def filter_packaged_entries(entries: list[tuple[str, ...]]) -> list[tuple[str, ...]]:
    return [entry for entry in entries if is_runtime_packaged_entry(entry)]


def collect_package_payload(package_name: str) -> tuple[list[tuple[str, str]], list[tuple[str, str]], list[str]]:
    pkg_datas, pkg_binaries, pkg_hidden = collect_or_empty(collect_all, package_name, ([], [], []))
    return (
        filter_packaged_entries(pkg_datas),
        filter_packaged_entries(pkg_binaries),
        pkg_hidden,
    )


def collect_package_dynamic_libs(package_name: str) -> list[tuple[str, str]]:
    return filter_packaged_entries(collect_or_empty(collect_dynamic_libs, package_name, []))


def collect_package_submodules(package_name: str) -> list[str]:
    return collect_or_empty(collect_submodules, package_name, [])


binaries: list[tuple[str, str]] = []
ffmpeg_path = os.path.join(project_dir, "bin", "ffmpeg.exe")
ffprobe_path = os.path.join(project_dir, "bin", "ffprobe.exe")
if os.path.exists(ffmpeg_path):
    binaries.append((ffmpeg_path, "bin"))
if os.path.exists(ffprobe_path):
    binaries.append((ffprobe_path, "bin"))

datas: list[tuple[str, str]] = []
hiddenimports: list[str] = []

for package_name in (
    "faster_whisper",
    "ctranslate2",
    "tokenizers",
    "av",
    "whisperx",
    "torch",
    "torchaudio",
):
    pkg_datas, pkg_binaries, pkg_hidden = collect_package_payload(package_name)
    datas += pkg_datas
    binaries += pkg_binaries
    hiddenimports += pkg_hidden

binaries += collect_package_dynamic_libs("av")

hiddenimports += collect_package_submodules("av")
hiddenimports += collect_package_submodules("whisperx")
hiddenimports += collect_package_submodules("torch")
hiddenimports += collect_package_submodules("torchaudio")

runtime_hooks = [os.path.join("runtime_hooks", "runtime_env_setup.py")]

from PyInstaller.building.build_main import Analysis, EXE, PYZ, COLLECT  # noqa: E402


def script_name(entry: object) -> str:
    name = getattr(entry, "name", None)
    if name:
        return name
    if isinstance(entry, tuple) and entry:
        return str(entry[0])
    return str(entry)


a = Analysis(
    ["engine/run_backend.py", "engine/run_runner.py", "engine/run_worker.py", "engine/run_align_worker.py"],
    pathex=[project_dir],
    binaries=binaries,
    datas=datas,
    hiddenimports=hiddenimports,
    hookspath=[],
    runtime_hooks=runtime_hooks,
    excludes=[],
    win_no_prefer_redirects=False,
    win_private_assemblies=False,
    cipher=block_cipher,
    noarchive=False,
)
a.datas = filter_packaged_entries(a.datas)
a.binaries = filter_packaged_entries(a.binaries)

pyz = PYZ(a.pure, a.zipped_data, cipher=block_cipher)

backend_exe = EXE(
    pyz,
    [
        script
        for script in a.scripts
        if os.path.splitext(os.path.basename(script_name(script)))[0] == "run_backend"
    ],
    [],
    exclude_binaries=True,
    name="CueBackend",
    debug=False,
    bootloader_ignore_signals=False,
    strip=False,
    upx=True,
    console=False,
    disable_windowed_traceback=False,
)

runner_exe = EXE(
    pyz,
    [
        script
        for script in a.scripts
        if os.path.splitext(os.path.basename(script_name(script)))[0] == "run_runner"
    ],
    [],
    exclude_binaries=True,
    name="CueRunner",
    debug=False,
    bootloader_ignore_signals=False,
    strip=False,
    upx=True,
    console=False,
    disable_windowed_traceback=False,
)

worker_exe = EXE(
    pyz,
    [
        script
        for script in a.scripts
        if os.path.splitext(os.path.basename(script_name(script)))[0] == "run_worker"
    ],
    [],
    exclude_binaries=True,
    name="CueWorker",
    debug=False,
    bootloader_ignore_signals=False,
    strip=False,
    upx=True,
    console=False,
    disable_windowed_traceback=False,
)

align_exe = EXE(
    pyz,
    [
        script
        for script in a.scripts
        if os.path.splitext(os.path.basename(script_name(script)))[0] == "run_align_worker"
    ],
    [],
    exclude_binaries=True,
    name="CueAlignWorker",
    debug=False,
    bootloader_ignore_signals=False,
    strip=False,
    upx=True,
    console=False,
    disable_windowed_traceback=False,
)

coll = COLLECT(
    backend_exe,
    runner_exe,
    worker_exe,
    align_exe,
    a.binaries,
    a.zipfiles,
    a.datas,
    strip=False,
    upx=True,
    upx_exclude=[],
    name="CueEngine",
)
